# --- apps/api (.env) ---
# Alchemy API key. If unset, the API serves realistic MOCK data so the app runs
# with no credentials. Get one free at https://dashboard.alchemy.com
ALCHEMY_API_KEY=""
# Port the Express API listens on
PORT=4000

# --- apps/web (.env.local) ---
# Base URL the web app uses to reach the API
NEXT_PUBLIC_API_URL="http://localhost:4000"
# WalletConnect/Reown project id for RainbowKit. If unset, only injected wallets
# (e.g. MetaMask) are offered. Get one free at https://dashboard.reown.com
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=""
